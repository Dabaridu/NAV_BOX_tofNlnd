#ifndef SENS_FUSION_H
#define SENS_FUSION_H

#include <math.h>

//IMU data
vector_t acc; //LINEAR acceleration (allready sensor fusion)
vector_t acc_prec; //acceleration and its precision from IMU
vector_t abs_q; //ABSOLUTE orientation as quaternion (allready sensor fusion)
//GPS data
vector_t pos; //lat, long, alt
vector_t pos_prec; //precision of position estimation

//Fusion data
vector_t X_global_translation = {0,0,0,0}; //global position estimation from IMU
vector_t O_global_orientation_euller = {0,0,0,0}; //global orientation estimation from IMU in euller angles
