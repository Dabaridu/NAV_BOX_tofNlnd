//estimation data
vector_t X_hat_estimation;
vector_t X_hat_precision;
vector_t O_hat_estimation;
vector_t O_hat_precision;




//standart BNO055 quaternion & vector struct 
//(for ease of use)
typedef struct { 
  double w;
  double x;
  double y;
  double z;
} vector_t;

//-----------------------------------------------------------------------------

void update_IMU_global_position(vector_t *acc, vector_t *acc_p, vector_t *abs_q, int time_step, vector_t *X_global_translation, vector_t *O_global_orientation_euller);

//merge GPS and IMU guesses in weighted average position estimation
vector_t joined_position_estimation(GPS_Position *gps_X, vector_t *imu_X, GPS_Precision *gps_prec, IMU_Precision *imu_prec);
vector_t joined_precision_calculation(GPS_Precision *gps, IMU_Precision *imu);

