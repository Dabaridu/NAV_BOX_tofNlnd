#include "main.h"
#include <stm32f3xx.h>
#include <nslp_dma.h>

#define type_GPS 0x0a 		//10
#define type_BNO055_g 0x0b	//11
#define type_BNO055_a 0x0c	//12
//#define type_BNO055_m 0x0d	//13
#define type_BMP 0x0e		//14
#define type_POS_F_X 0x0f		//15



//-----------------------------Structures----------------------------------------------

struct Position {
	float latitude;
	float longitude;
	float altitude;
	uint32_t fixType;
	uint32_t numSV;

	uint32_t time;
};
struct Position GPS_data = {
		.latitude = 1.0,
		.longitude = 0.0,
		.altitude = 0.0,
		.fixType = 0,
		.numSV = 0
};

struct BNO055_payload_a {
	double ax;
	double ay;
	double az;
	uint32_t time;
};
struct BNO055_payload_a BNO055_data_a;

struct BMP_payload {
	float temp;
	uint32_t press;

	uint32_t time;
};
struct BMP_payload BMP_data;

struct BNO055_payload_g {
	//uint32_t calib; //8 --> 32 bit

	double gx;
	double gy;
	double gz;
	uint32_t time;
};
struct BNO055_payload_g BNO055_data_g;

struct position_fusion_payload {

	double Xx;
	double Xy;
	double Xz;

	uint32_t ts;
};

struct position_fusion POS_fusion_X;

