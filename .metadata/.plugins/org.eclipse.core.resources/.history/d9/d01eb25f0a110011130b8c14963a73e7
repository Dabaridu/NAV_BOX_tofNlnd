#include "sens_fusion.h"

//IMU data
vector_t acc = {0,0,0,0};
vector_t acc_prec = {0,0,0,0};
vector_t abs_q = {0,0,0,0};
//GPS data
vector_t pos = {0,0,0,0};
vector_t pos_prec = {0,0,0,0};

//Fusion data
vector_t X_global_translation = {0,0,0,0};
vector_t O_global_orientation_euller = {0,0,0,0};

//estimation data
vector_t X_hat_estimation = {0,0,0,0};
vector_t X_hat_precision = {0,0,0,0};
vector_t O_hat_estimation = {0,0,0,0};
vector_t O_hat_precision = {0,0,0,0};

int time_step = 0;
int last_time = 0;

void update_IMU_global_position(float starting_position_offset[1][3],float starting_orientation_offset[3][3],vector_t *acc, vector_t *abs_q, int time_step, vector_t *X_global_translation, vector_t *O_global_orientation_euller){
    // Rotation matrix from quaternion (4x4 homogeneous transformation matrix)
    float H[4][4];
    
    // Quaternion components: abs_q->w, abs_q->x, abs_q->y, abs_q->z
    float w = abs_q->w;
    float x = abs_q->x;
    float y = abs_q->y;
    float z = abs_q->z;
    
    // Compute rotation matrix from quaternion
    float R[3][3] = {
        {1 - 2*(y*y + z*z), 2*(x*y - w*z), 2*(x*z + w*y)},
        {2*(x*y + w*z), 1 - 2*(x*x + z*z), 2*(y*z - w*x)},
        {2*(x*z - w*y), 2*(y*z + w*x), 1 - 2*(x*x + y*y)}
    };
    
    // Rotate starting_orientation_offset by quaternion rotation
    float rotated[3][3];
    for(int i = 0; i < 3; i++){
        for(int j = 0; j < 3; j++){
            rotated[i][j] = 0;
            for(int k = 0; k < 3; k++){
                rotated[i][j] += R[i][k] * starting_orientation_offset[k][j];
            }
        }
    }
    
    // Build 4x4 homogeneous transformation matrix H
    for(int i = 0; i < 3; i++){
        for(int j = 0; j < 3; j++){
            H[i][j] = rotated[i][j];
        }
        // Add starting position offset to the translation column
        H[i][3] = starting_position_offset[0][i];
    }
    // Bottom row of homogeneous matrix
    H[3][0] = 0;
    H[3][1] = 0;
    H[3][2] = 0;
    H[3][3] = 1;

    float T[4][4];
    T[0][0] = 1; T[0][1] = 0; T[0][2] = 0; T[0][3] = acc->x*(time_step*time_step/2);
    T[1][0] = 0; T[1][1] = 1; T[1][2] = 0; T[1][3] = acc->y*(time_step*time_step/2);
    T[2][0] = 0; T[2][1] = 0; T[2][2] = 1; T[2][3] = acc->z*(time_step*time_step/2);
    T[3][0] = 0; T[3][1] = 0; T[3][2] = 0; T[3][3] = 1;

    matrix_multiply(H, T, H); // Update H with new translation from acceleration

    // Extract global translation and orientation from H
    X_global_translation->x = H[0][3];
    X_global_translation->y = H[1][3];
    X_global_translation->z = H[2][3];
    // Convert rotation part of H back to Euler angles (roll, pitch, yaw)
    float sy = sqrt(H[0][0] * H[0][0] + H[1][0] * H[1][0]);
    bool singular = sy < 1e-6; // If
    if (!singular) {
        O_global_orientation_euller->x = atan2(H[2][1], H[2][2]); // roll
        O_global_orientation_euller->y = atan2(-H[2][0], sy); // pitch
        O_global_orientation_euller->z = atan2(H[1][0], H[0][0]); // yaw
    } else {
        O_global_orientation_euller->x = atan2(-H[1][2], H[1][1]); // roll
        O_global_orientation_euller->y = atan2(-H[2][0], sy); // pitch
        O_global_orientation_euller->z = 0; // yaw is undefined in singularity
    }
}

void update_position_precision_calculation(vector_t *acc_prec,int time_step){
    // Simple model: precision degrades over time due to drift
    acc_prec->x += 1/sqrt(3) * sqrt(time_step*time_step*time_step); // Increase variance in x
    acc_prec->y += 1/sqrt(3) * sqrt(time_step*time_step*time_step); // Increase variance in y
    acc_prec->z += 1/sqrt(3) * sqrt(time_step*time_step*time_step); // Increase variance in z
}

void joined_position_estimation(vector_t *X_hat_estimation, vector_t *pos, vector_t *imu_X, vector_t *pos_prec, vector_t *acc_prec){
    float gps_weight = 1 / (pos_prec->x + pos_prec->y + pos_prec->z);
    float imu_weight = 1 / (acc_prec->x + acc_prec->y + acc_prec->z);

    float total_weight = gps_weight + imu_weight;

    float estimated_latitude = (pos->x * gps_weight + imu_X->x * imu_weight) / total_weight;
    float estimated_longitude = (pos->y * gps_weight + imu_X->y * imu_weight) / total_weight;
    float estimated_altitude = (pos->z * gps_weight + imu_X->z * imu_weight) / total_weight;

    X_hat_estimation->x = estimated_latitude;
    X_hat_estimation->y = estimated_longitude;
    X_hat_estimation->z = estimated_altitude;
}

void joined_precision_calculation(vector_t *X_hat_precision, vector_t *pos_prec, vector_t *acc_prec){
    float gps_variance = pos_prec->x + pos_prec->y + pos_prec->z;
    float imu_variance = acc_prec->x + acc_prec->y + acc_prec->z;

    float combined_variance = 1 / (1 / gps_variance + 1 / imu_variance);
    X_hat_precision->x = combined_variance;
    X_hat_precision->y = combined_variance;
    X_hat_precision->z = combined_variance;
}

//-----------------------------------------------------Support functions------------------------------------------------------------------------------------------------------

int update_time_step(int *last_time, int current_time){
    int time_step = current_time - *last_time;
    *last_time = current_time;
    return time_step;
}
