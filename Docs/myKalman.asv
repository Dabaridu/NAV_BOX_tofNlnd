t = 0:Ts:Tend
m_s1 = randometime(t,10,1,2); %GPS
m_s2 = randometime(t,3,0.5,0.1); %IMU

plot(t,m_s1)
plot(t,m_s2)


Kalman1 = KF;
GPS = KFsens;
IMU = KFsens;

z = [0 0 1];

for i = 1:numel(t)
    if(m_s1(i) == 1)

    else

end

Kalman1.kalman_step_predict_3(Ts)
Kalman1.kalman_step_update_3(GPS,z)


Kalman1.kalman_step_predict_3(Ts)
